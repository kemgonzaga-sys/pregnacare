# ── SERVER ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ── PostgreSQL ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pregnacare
DB_USER=pregnacare_user
DB_PASSWORD=your_secure_password_here
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=false                    # Set true in production

# ── Redis ────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                 # Leave blank for local dev
REDIS_TTL_SECONDS=3600          # Default cache TTL: 1 hour

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=replace_with_64_char_random_secret_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_another_64_char_secret
JWT_REFRESH_EXPIRES_IN=30d

# ── SECURITY ─────────────────────────────────────────────
BCRYPT_ROUNDS=12
PIN_MAX_ATTEMPTS=5
PIN_LOCKOUT_MINUTES=15
RATE_LIMIT_WINDOW_MS=900000     # 15 minutes
RATE_LIMIT_MAX=100

# ── ANTHROPIC (AI Coach proxy) ───────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=1024

# ── NOTIFICATIONS ─────────────────────────────────────────
FCM_SERVER_KEY=                 # Firebase Cloud Messaging
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── APP ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:8080
EMERGENCY_SMS_PROVIDER=semaphore  # PH SMS provider
EMERGENCY_SMS_KEY=
