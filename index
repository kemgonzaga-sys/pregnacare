<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PregnaCare</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --rose: #F4728B;
  --rose-light: #FDE8ED;
  --rose-dark: #C94F6A
  --rose: #F4728B;
  --rose-light: #FDE8ED;
  --rose-dark: #C94F6A;
  --rose-deeper: #8B2A40;
  --peach: #F9A48A;
  --peach-light: #FEF0EA;
  --lavender: #C4B5F4;
  --lavender-light: #EDE8FD;
  --lavender-dark: #7C5FD4;
  --mint: #6DD4B4;
  --mint-light: #E0F7F0;
  --mint-dark: #2A8F70;
  --amber: #F9C74F;
  --amber-light: #FEF6DC;
  --text-primary: #1A0A10;
  --text-secondary: #6B4455;
  --text-muted: #A07888;
  --bg: #FFFBFC;
  --surface: #FFFFFF;
  --surface2: #FDF5F7;
  --border: rgba(244,114,139,0.15);
  --border2: rgba(244,114,139,0.3);
  --shadow: 0 4px 24px rgba(180,60,90,0.08);
  --shadow-lg: 0 12px 48px rgba(180,60,90,0.14);
  --radius: 16px;
  --radius-sm: 10px;
  --radius-xs: 6px;
}
 
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
 
body {
  font-family: 'DM Sans', sans-serif;
  background: var(--bg);
  color: var(--text-primary);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}
 
/* ── LOCK SCREEN ── */
#lock-screen {
  position: fixed; inset: 0; background: linear-gradient(160deg, #FDE8ED 0%, #EDE8FD 50%, #E0F7F0 100%);
  display: flex; align-items: center; justify-content: center; z-index: 9999; flex-direction: column; gap: 32px;
}
.lock-logo { text-align: center; }
.lock-logo-icon { width: 80px; height: 80px; background: white; border-radius: 24px; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; box-shadow: 0 8px 32px rgba(180,60,90,0.2); }
.lock-logo-icon svg { width: 44px; height: 44px; }
.lock-logo h1 { font-family: 'DM Serif Display', serif; font-size: 36px; color: var(--rose-dark); }
.lock-logo p { color: var(--text-secondary); font-size: 15px; margin-top: 4px; }
.pin-box { background: white; border-radius: 24px; padding: 32px; box-shadow: var(--shadow-lg); text-align: center; width: 320px; }
.pin-box h3 { font-size: 16px; font-weight: 500; color: var(--text-secondary); margin-bottom: 20px; }
.pin-dots { display: flex; justify-content: center; gap: 12px; margin-bottom: 24px; }
.pin-dot { width: 14px; height: 14px; border-radius: 50%; border: 2px solid var(--rose); transition: background 0.2s; }
.pin-dot.filled { background: var(--rose); }
.pin-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
.pin-btn { background: var(--surface2); border: none; border-radius: var(--radius-sm); padding: 16px; font-size: 20px; font-weight: 500; color: var(--text-primary); cursor: pointer; transition: background 0.15s, transform 0.1s; font-family: 'DM Sans', sans-serif; }
.pin-btn:hover { background: var(--rose-light); }
.pin-btn:active { transform: scale(0.95); background: var(--rose-light); }
.pin-btn.del { font-size: 14px; color: var(--text-muted); }
.biometric-btn { margin-top: 16px; display: flex; align-items: center; justify-content: center; gap: 8px; color: var(--rose); font-size: 14px; cursor: pointer; background: none; border: none; font-family: 'DM Sans', sans-serif; font-weight: 500; }
 
/* ── ONBOARDING ── */
#onboarding {
  position: fixed; inset: 0; background: white; z-index: 9998; display: flex; flex-direction: column;
  display: none;
}
.ob-step { display: none; flex-direction: column; height: 100%; }
.ob-step.active { display: flex; }
.ob-hero { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40px 32px; text-align: center; }
.ob-emoji { font-size: 72px; margin-bottom: 24px; }
.ob-hero h2 { font-family: 'DM Serif Display', serif; font-size: 30px; color: var(--rose-dark); margin-bottom: 12px; line-height: 1.2; }
.ob-hero p { color: var(--text-secondary); font-size: 16px; line-height: 1.6; max-width: 300px; }
.ob-footer { padding: 24px 32px; border-top: 1px solid var(--border); }
.ob-footer .primary-btn { width: 100%; }
.ob-dots { display: flex; justify-content: center; gap: 8px; margin-bottom: 20px; }
.ob-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--border2); transition: all 0.2s; }
.ob-dot.active { background: var(--rose); width: 24px; border-radius: 4px; }
.mode-cards { display: flex; flex-direction: column; gap: 16px; width: 100%; margin-top: 24px; }
.mode-card { padding: 20px; border-radius: var(--radius); border: 2px solid var(--border); cursor: pointer; transition: all 0.2s; text-align: left; background: white; }
.mode-card:hover, .mode-card.selected { border-color: var(--rose); background: var(--rose-light); }
.mode-card h4 { font-weight: 600; font-size: 16px; margin-bottom: 4px; }
.mode-card p { font-size: 13px; color: var(--text-secondary); }
 
/* ── MAIN APP ── */
#app { display: none; flex-direction: column; min-height: 100vh; }
#app.visible { display: flex; }
 
/* HEADER */
.app-header { background: white; border-bottom: 1px solid var(--border); padding: 16px 20px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 100; }
.header-left { display: flex; align-items: center; gap: 12px; }
.header-logo { font-family: 'DM Serif Display', serif; font-size: 22px; color: var(--rose-dark); }
.mode-badge { padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; letter-spacing: 0.03em; }
.mode-badge.pregnancy { background: var(--rose-light); color: var(--rose-dark); }
.mode-badge.period { background: var(--lavender-light); color: var(--lavender-dark); }
.header-right { display: flex; align-items: center; gap: 10px; }
.icon-btn { width: 36px; height: 36px; border-radius: var(--radius-xs); background: var(--surface2); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; cursor: pointer; }
.icon-btn:hover { background: var(--rose-light); }
.avatar { width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, var(--rose), var(--peach)); display: flex; align-items: center; justify-content: center; color: white; font-weight: 600; font-size: 14px; cursor: pointer; }
 
/* BOTTOM NAV */
.bottom-nav { background: white; border-top: 1px solid var(--border); padding: 8px 0 12px; display: flex; position: fixed; bottom: 0; left: 0; right: 0; z-index: 100; }
.nav-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; cursor: pointer; padding: 6px 4px; transition: all 0.2s; }
.nav-item svg { width: 22px; height: 22px; transition: all 0.2s; }
.nav-item span { font-size: 10px; font-weight: 500; color: var(--text-muted); transition: color 0.2s; }
.nav-item.active span { color: var(--rose); }
.nav-item.active svg { color: var(--rose); }
.nav-item:not(.active) svg { color: var(--text-muted); }
 
/* MAIN CONTENT */
.main-content { flex: 1; padding: 20px; padding-bottom: 90px; max-width: 480px; margin: 0 auto; width: 100%; }
 
/* SECTION SCREENS */
.screen { display: none; }
.screen.active { display: block; }
 
/* ── COMPONENTS ── */
.primary-btn {
  background: linear-gradient(135deg, var(--rose), var(--rose-dark));
  color: white; border: none; border-radius: var(--radius-sm); padding: 14px 24px;
  font-size: 15px; font-weight: 600; cursor: pointer; font-family: 'DM Sans', sans-serif;
  transition: all 0.2s; box-shadow: 0 4px 16px rgba(244,114,139,0.3);
}
.primary-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(244,114,139,0.4); }
.primary-btn:active { transform: translateY(0); }
 
.secondary-btn {
  background: var(--surface2); color: var(--text-secondary); border: 1px solid var(--border2);
  border-radius: var(--radius-sm); padding: 12px 20px; font-size: 14px; font-weight: 500;
  cursor: pointer; font-family: 'DM Sans', sans-serif; transition: all 0.2s;
}
.secondary-btn:hover { background: var(--rose-light); color: var(--rose-dark); border-color: var(--rose); }
 
.card { background: white; border-radius: var(--radius); border: 1px solid var(--border); padding: 20px; margin-bottom: 16px; box-shadow: var(--shadow); }
.card-sm { background: white; border-radius: var(--radius-sm); border: 1px solid var(--border); padding: 14px; }
 
.section-title { font-size: 13px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 12px; }
 
.tag { display: inline-block; padding: 4px 10px; border-radius: 20px; font-size: 12px; font-weight: 500; }
.tag-rose { background: var(--rose-light); color: var(--rose-dark); }
.tag-mint { background: var(--mint-light); color: var(--mint-dark); }
.tag-lavender { background: var(--lavender-light); color: var(--lavender-dark); }
.tag-amber { background: var(--amber-light); color: #8B6200; }
 
/* PROGRESS RING */
.progress-ring-wrap { position: relative; display: inline-flex; }
.progress-ring-label { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; }
 
/* MOOD PILLS */
.mood-row { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px; }
.mood-pill { padding: 8px 14px; border-radius: 20px; font-size: 14px; border: 1.5px solid var(--border2); background: white; cursor: pointer; transition: all 0.15s; font-family: 'DM Sans', sans-serif; }
.mood-pill:hover, .mood-pill.selected { background: var(--rose-light); border-color: var(--rose); }
 
/* CALENDAR */
.calendar-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px; }
.cal-header { display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px; margin-bottom: 6px; }
.cal-day-name { text-align: center; font-size: 11px; font-weight: 600; color: var(--text-muted); padding: 4px; }
.cal-day { aspect-ratio: 1; display: flex; align-items: center; justify-content: center; border-radius: 50%; font-size: 13px; cursor: pointer; transition: all 0.15s; position: relative; }
.cal-day:hover { background: var(--surface2); }
.cal-day.today { font-weight: 700; color: var(--rose-dark); }
.cal-day.period { background: var(--rose-light); color: var(--rose-dark); font-weight: 600; }
.cal-day.fertile { background: var(--mint-light); color: var(--mint-dark); }
.cal-day.ovulation { background: var(--mint); color: white; }
.cal-day.predicted { background: var(--lavender-light); color: var(--lavender-dark); }
 
/* FLOW INDICATOR */
.flow-bar { display: flex; gap: 4px; align-items: flex-end; height: 32px; }
.flow-seg { width: 8px; border-radius: 4px; background: var(--rose-light); transition: all 0.2s; cursor: pointer; }
.flow-seg.active { background: var(--rose); }
 
/* CHAT */
.chat-messages { display: flex; flex-direction: column; gap: 12px; margin-bottom: 16px; }
.chat-bubble { padding: 12px 16px; border-radius: var(--radius); max-width: 85%; font-size: 14px; line-height: 1.5; }
.chat-bubble.ai { background: var(--surface2); color: var(--text-primary); align-self: flex-start; border-bottom-left-radius: 4px; border: 1px solid var(--border); }
.chat-bubble.user { background: linear-gradient(135deg, var(--rose), var(--rose-dark)); color: white; align-self: flex-end; border-bottom-right-radius: 4px; }
.chat-input-row { display: flex; gap: 10px; }
.chat-input { flex: 1; padding: 12px 16px; border-radius: var(--radius-sm); border: 1.5px solid var(--border2); font-family: 'DM Sans', sans-serif; font-size: 14px; outline: none; transition: border 0.2s; background: white; }
.chat-input:focus { border-color: var(--rose); }
.send-btn { width: 44px; height: 44px; border-radius: var(--radius-xs); background: var(--rose); border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; color: white; transition: all 0.2s; flex-shrink: 0; }
.send-btn:hover { background: var(--rose-dark); }
 
/* EMERGENCY BTN */
.emergency-btn { background: linear-gradient(135deg, #FF4444, #CC1111); color: white; border: none; border-radius: var(--radius); padding: 20px; width: 100%; font-size: 18px; font-weight: 700; cursor: pointer; font-family: 'DM Sans', sans-serif; display: flex; align-items: center; justify-content: center; gap: 12px; box-shadow: 0 8px 32px rgba(255,68,68,0.35); transition: all 0.2s; margin-bottom: 16px; }
.emergency-btn:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(255,68,68,0.45); }
.emergency-btn:active { transform: scale(0.98); }
 
/* TYPING INDICATOR */
.typing { display: flex; gap: 4px; align-items: center; padding: 12px 16px; }
.dot { width: 8px; height: 8px; border-radius: 50%; background: var(--text-muted); animation: bounce 1.2s infinite; }
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes bounce { 0%,60%,100% { transform: translateY(0); } 30% { transform: translateY(-6px); } }
 
/* RISK METER */
.risk-meter { position: relative; height: 12px; background: linear-gradient(to right, #6DD4B4, #F9C74F, #F4728B, #CC1111); border-radius: 6px; margin: 12px 0; }
.risk-thumb { position: absolute; top: -4px; width: 20px; height: 20px; border-radius: 50%; background: white; border: 3px solid var(--rose); transform: translateX(-50%); box-shadow: 0 2px 8px rgba(0,0,0,0.15); transition: left 0.5s ease; }
 
/* WEARABLE STATS */
.vitals-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.vital-card { background: var(--surface2); border-radius: var(--radius-sm); padding: 14px; text-align: center; }
.vital-value { font-size: 28px; font-weight: 600; }
.vital-label { font-size: 12px; color: var(--text-muted); margin-top: 2px; }
.vital-status { font-size: 11px; font-weight: 600; margin-top: 4px; }
.vital-status.good { color: var(--mint-dark); }
.vital-status.warn { color: #B86B00; }
 
/* AR VIEWER */
.ar-viewer { background: linear-gradient(160deg, #0D0A1A, #1A0F2E); border-radius: var(--radius); padding: 30px; text-align: center; position: relative; overflow: hidden; }
.ar-fetus { font-size: 80px; margin-bottom: 16px; filter: drop-shadow(0 0 20px rgba(196,181,244,0.5)); animation: float 3s ease-in-out infinite; }
@keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }
.ar-viewer h3 { color: white; font-family: 'DM Serif Display', serif; font-size: 20px; margin-bottom: 8px; }
.ar-viewer p { color: rgba(255,255,255,0.7); font-size: 14px; }
 
/* QUICK LOG ROW */
.quick-log-row { display: flex; gap: 8px; overflow-x: auto; padding-bottom: 4px; scrollbar-width: none; }
.quick-log-row::-webkit-scrollbar { display: none; }
.quick-log-item { flex-shrink: 0; display: flex; flex-direction: column; align-items: center; gap: 6px; padding: 12px 14px; background: white; border: 1.5px solid var(--border); border-radius: var(--radius-sm); cursor: pointer; transition: all 0.15s; }
.quick-log-item:hover, .quick-log-item.selected { border-color: var(--rose); background: var(--rose-light); }
.quick-log-item span:first-child { font-size: 22px; }
.quick-log-item span:last-child { font-size: 11px; font-weight: 500; color: var(--text-secondary); }
 
/* FOOD SCANNER */
.scanner-box { background: linear-gradient(160deg, #0D0A1A, #1A0A10); border-radius: var(--radius); padding: 30px; text-align: center; position: relative; overflow: hidden; margin-bottom: 16px; }
.scan-frame { width: 180px; height: 180px; margin: 0 auto 20px; position: relative; }
.scan-frame::before, .scan-frame::after { content: ''; position: absolute; width: 40px; height: 40px; border-color: var(--rose); border-style: solid; }
.scan-frame::before { top: 0; left: 0; border-width: 3px 0 0 3px; border-radius: 8px 0 0 0; }
.scan-frame::after { bottom: 0; right: 0; border-width: 0 3px 3px 0; border-radius: 0 0 8px 0; }
.scan-inner { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-size: 60px; }
.scan-line { position: absolute; left: 0; right: 0; height: 2px; background: linear-gradient(to right, transparent, var(--rose), transparent); animation: scan 2s linear infinite; }
@keyframes scan { 0% { top: 10%; } 100% { top: 90%; } }
.scanner-box p { color: rgba(255,255,255,0.7); font-size: 14px; }
 
/* COMMUNITY */
.community-post { padding: 16px; border-bottom: 1px solid var(--border); }
.community-post:last-child { border-bottom: none; }
.post-header { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
.post-avatar { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 16px; }
.post-meta { flex: 1; }
.post-name { font-weight: 600; font-size: 14px; }
.post-time { font-size: 12px; color: var(--text-muted); }
.post-body { font-size: 14px; line-height: 1.6; color: var(--text-secondary); }
.post-actions { display: flex; gap: 16px; margin-top: 10px; }
.post-action { display: flex; align-items: center; gap: 4px; font-size: 13px; color: var(--text-muted); cursor: pointer; transition: color 0.15s; background: none; border: none; font-family: 'DM Sans', sans-serif; }
.post-action:hover { color: var(--rose); }
 
/* CYCLE INSIGHTS */
.insight-row { display: flex; align-items: center; gap: 12px; padding: 12px 0; border-bottom: 1px solid var(--border); }
.insight-row:last-child { border-bottom: none; }
.insight-icon { width: 36px; height: 36px; border-radius: var(--radius-xs); display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 18px; }
.insight-text { flex: 1; }
.insight-text strong { display: block; font-size: 14px; font-weight: 600; }
.insight-text span { font-size: 13px; color: var(--text-muted); }
 
/* SWITCH BANNER */
.switch-banner { background: linear-gradient(135deg, var(--rose), var(--lavender-dark)); border-radius: var(--radius); padding: 20px; color: white; display: flex; align-items: center; gap: 16px; margin-bottom: 16px; }
.switch-banner-text h3 { font-size: 16px; font-weight: 700; margin-bottom: 4px; }
.switch-banner-text p { font-size: 13px; opacity: 0.9; }
.switch-banner-btn { background: white; color: var(--rose-dark); border: none; border-radius: var(--radius-xs); padding: 10px 16px; font-size: 13px; font-weight: 700; cursor: pointer; flex-shrink: 0; font-family: 'DM Sans', sans-serif; white-space: nowrap; }
 
/* TOAST */
.toast { position: fixed; bottom: 100px; left: 50%; transform: translateX(-50%) translateY(20px); background: var(--text-primary); color: white; padding: 12px 20px; border-radius: var(--radius-sm); font-size: 14px; font-weight: 500; opacity: 0; transition: all 0.3s; z-index: 9999; pointer-events: none; white-space: nowrap; }
.toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
 
/* REMINDER ITEM */
.reminder-item { display: flex; align-items: center; gap: 12px; padding: 14px; background: var(--surface2); border-radius: var(--radius-sm); margin-bottom: 10px; }
.reminder-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
.reminder-text { flex: 1; }
.reminder-text strong { display: block; font-size: 14px; font-weight: 600; }
.reminder-text span { font-size: 12px; color: var(--text-muted); }
.reminder-time { font-size: 12px; font-weight: 600; color: var(--text-secondary); }
 
/* RANGE INPUT */
input[type=range] { -webkit-appearance: none; width: 100%; height: 6px; border-radius: 3px; background: var(--rose-light); outline: none; }
input[type=range]::-webkit-slider-thumb { -webkit-appearance: none; width: 20px; height: 20px; border-radius: 50%; background: var(--rose); cursor: pointer; box-shadow: 0 2px 8px rgba(244,114,139,0.4); }
 
/* STATS ROW */
.stats-row { display: flex; gap: 10px; margin-bottom: 16px; }
.stat-box { flex: 1; background: white; border-radius: var(--radius-sm); border: 1px solid var(--border); padding: 14px; text-align: center; }
.stat-box .value { font-size: 24px; font-weight: 700; }
.stat-box .label { font-size: 11px; color: var(--text-muted); margin-top: 2px; font-weight: 500; }
 
/* WEEK INDICATOR */
.week-arc { display: flex; justify-content: center; padding: 20px 0; }
.week-circle { width: 120px; height: 120px; position: relative; }
.week-circle-inner { position: absolute; inset: 12px; background: white; border-radius: 50%; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.week-circle-inner .week-num { font-family: 'DM Serif Display', serif; font-size: 32px; color: var(--rose-dark); line-height: 1; }
.week-circle-inner .week-label { font-size: 11px; color: var(--text-muted); font-weight: 500; }
 
/* BREASTFEEDING */
.latch-visual { display: flex; justify-content: center; gap: 20px; margin: 16px 0; }
.latch-side { text-align: center; }
.latch-timer { font-size: 32px; font-weight: 700; color: var(--rose-dark); font-family: 'DM Serif Display', serif; }
.latch-btn { margin-top: 8px; padding: 8px 18px; border-radius: 20px; border: 2px solid var(--rose); background: transparent; color: var(--rose-dark); font-weight: 600; cursor: pointer; font-family: 'DM Sans', sans-serif; font-size: 13px; transition: all 0.2s; }
.latch-btn.running { background: var(--rose); color: white; }
 
/* TABS */
.tabs { display: flex; background: var(--surface2); border-radius: var(--radius-sm); padding: 4px; margin-bottom: 20px; }
.tab { flex: 1; padding: 10px; text-align: center; font-size: 13px; font-weight: 500; border-radius: var(--radius-xs); cursor: pointer; transition: all 0.2s; color: var(--text-muted); }
.tab.active { background: white; color: var(--rose-dark); box-shadow: 0 2px 8px rgba(0,0,0,0.08); font-weight: 600; }
 
/* HUB ARTICLE */
.hub-article { padding: 16px; border-bottom: 1px solid var(--border); display: flex; gap: 14px; cursor: pointer; align-items: flex-start; }
.hub-article:hover { background: var(--surface2); }
.hub-article-emoji { font-size: 28px; flex-shrink: 0; }
.hub-article-text h4 { font-size: 15px; font-weight: 600; margin-bottom: 4px; }
.hub-article-text p { font-size: 13px; color: var(--text-muted); line-height: 1.5; }
 
/* VOICE BTN */
