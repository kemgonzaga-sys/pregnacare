            <button class="post-action" onclick="likePost(this)"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg> 102 Likes</button>
            <button class="post-action" onclick="showToast('Nagkomento...')"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg> 45 Replies</button>
          </div>
        </div>
      </div>
    </div>
 
  </div><!-- /main-content -->
 
  <!-- BOTTOM NAV -->
  <nav class="bottom-nav">
    <div class="nav-item active" id="nav-home" onclick="navigate('home')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      <span>Home</span>
    </div>
    <div class="nav-item" id="nav-food" onclick="navigate('food')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <span>Food</span>
    </div>
    <div class="nav-item" id="nav-chat" onclick="navigate('chat')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      <span>Coach</span>
    </div>
    <div class="nav-item" id="nav-wellness" onclick="navigate('wellness')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      <span>Wellness</span>
    </div>
    <div class="nav-item" id="nav-community" onclick="navigate('community')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      <span>Community</span>
    </div>
  </nav>
</div><!-- /app -->
 
<!-- TOAST -->
<div class="toast" id="toast"></div>
 
<script>
// ── STATE ──
let currentPin = '';
let currentMode = 'pregnancy'; // 'pregnancy' | 'period'
let currentScreen = 'home';
let obSelectedMode = null;
let calMonth = 2; // March (0-based) = 2
let calYear = 2026;
let timers = { left: { running: false, seconds: 504, interval: null }, right: { running: false, seconds: 0, interval: null } };
 
// ── PIN LOGIC ──
function pinInput(v) {
  if (!v) return;
  if (currentPin.length >= 4) return;
  currentPin += v;
  updateDots();
  if (currentPin.length === 4) {
    setTimeout(() => {
      if (currentPin === '1234' || currentPin.length === 4) unlockApp();
      else { currentPin = ''; updateDots(); showToast('Maling PIN. Subukang muli.'); }
    }, 200);
  }
}
function pinDel() { currentPin = currentPin.slice(0, -1); updateDots(); }
function updateDots() {
  for (let i = 1; i <= 4; i++) {
    document.getElementById('d' + i).classList.toggle('filled', i <= currentPin.length);
  }
}
function unlockApp() {
  document.getElementById('lock-screen').style.display = 'none';
  document.getElementById('onboarding').style.display = 'flex';
}
 
// ── ONBOARDING ──
function nextOb(step) {
  document.querySelectorAll('.ob-step').forEach(s => s.classList.remove('active'));
  document.getElementById('ob' + step).classList.add('active');
}
function selectMode(mode) {
  obSelectedMode = mode;
  document.querySelectorAll('.mode-card').forEach(c => c.classList.remove('selected'));
  document.getElementById('mc-' + mode).classList.add('selected');
  const btn = document.getElementById('ob-start-btn');
  btn.style.opacity = '1'; btn.style.pointerEvents = '';
}
function startApp() {
  if (!obSelectedMode) return;
  currentMode = obSelectedMode;
  document.getElementById('onboarding').style.display = 'none';
  const app = document.getElementById('app');
  app.style.display = 'flex';
  app.classList.add('visible');
  setMode(currentMode);
  buildCalendar();
}
 
// ── MODE SWITCHING ──
function setMode(mode) {
  currentMode = mode;
  const badge = document.getElementById('mode-badge');
  if (mode === 'pregnancy') {
    badge.textContent = 'Pregnancy'; badge.className = 'mode-badge pregnancy';
    document.getElementById('screen-home-pregnancy').classList.add('active');
    document.getElementById('screen-home-period').classList.remove('active');
  } else {
    badge.textContent = 'Period Tracker'; badge.className = 'mode-badge period';
    document.getElementById('screen-home-pregnancy').classList.remove('active');
    document.getElementById('screen-home-period').classList.add('active');
  }
}
function toggleMode() {
  const newMode = currentMode === 'pregnancy' ? 'period' : 'pregnancy';
  setMode(newMode);
  if (currentScreen === 'home') {} // already handled
  showToast(newMode === 'pregnancy' ? 'Pregnancy Mode ✅' : 'Period Tracker Mode ✅');
}
function switchToPregnancy() {
  setMode('pregnancy');
  navigate('home');
  showToast('Na-carry over ang cycle history mo! 🌸');
}
 
// ── NAVIGATION ──
function navigate(screen) {
  currentScreen = screen;
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  
  if (screen === 'home') {
    if (currentMode === 'pregnancy') document.getElementById('screen-home-pregnancy').classList.add('active');
    else document.getElementById('screen-home-period').classList.add('active');
    document.getElementById('nav-home').classList.add('active');
  } else {
    document.getElementById('screen-' + screen).classList.add('active');
    document.getElementById('nav-' + screen).classList.add('active');
  }
}
 
// ── CALENDAR ──
function buildCalendar() {
  const months = ['Enero','Pebrero','Marso','Abril','Mayo','Hunyo','Hulyo','Agosto','Setyembre','Oktubre','Nobyembre','Disyembre'];
  document.getElementById('cal-month-label').textContent = months[calMonth] + ' ' + calYear;
  
  const grid = document.getElementById('cal-grid');
  grid.innerHTML = '';
  
  const firstDay = new Date(calYear, calMonth, 1).getDay();
  const daysInMonth = new Date(calYear, calMonth + 1, 0).getDate();
  const today = new Date(); 
  const isCurrentMonth = today.getMonth() === calMonth && today.getFullYear() === calYear;
  
  // Period days (example: 5-9), fertile 12-17, ovulation 14, predicted next: Apr 3-7
  const periodDays = [5,6,7,8,9];
  const fertileDays = [12,13,15,16,17];
  const ovulationDay = 14;
  const predictedDays = []; // next month
  
  for (let i = 0; i < firstDay; i++) { 
    const blank = document.createElement('div');
    blank.className = 'cal-day';
    grid.appendChild(blank);
  }
  for (let d = 1; d <= daysInMonth; d++) {
    const el = document.createElement('div');
    el.className = 'cal-day';
    el.textContent = d;
    if (isCurrentMonth && d === today.getDate()) el.classList.add('today');
    if (periodDays.includes(d)) el.classList.add('period');
    else if (d === ovulationDay) el.classList.add('ovulation');
    else if (fertileDays.includes(d)) el.classList.add('fertile');
    el.onclick = () => showToast('Day ' + d + ' logged!');
    grid.appendChild(el);
  }
}
function prevMonth() { calMonth--; if (calMonth < 0) { calMonth = 11; calYear--; } buildCalendar(); }
function nextMonth() { calMonth++; if (calMonth > 11) { calMonth = 0; calYear++; } buildCalendar(); }
 
// ── FOOD SCANNER ──
function showFoodResult() {
  showToast('Scanning... 🍛 Nakita: Sinangag at Itlog');
  setTimeout(() => { document.getElementById('food-result').style.display = 'block'; }, 800);
}
 
// ── CHAT ──
const aiResponses = {
  preg: [
    'Salamat sa tanong! Batay sa iyong profile at 24 weeks, narito ang DOH-aligned na sagot: ',
    'Napakahalagang tanong iyan para sa iyong kaligtasan at ng iyong baby. Ganito ang rekomendasyon: ',
    'Ayon sa World Health Organization at DOH guidelines para sa pagbubuntis: ',
  ],
  period: [
    'Narito ang impormasyon tungkol sa iyong menstrual health: ',
    'Batay sa DOH guidelines at ang iyong cycle history: ',
    'Magandang tanong! Para sa menstrual health, ganito ang masasabi natin: ',
  ]
};
 
function sendChat(type) {
  const inp = document.getElementById('chat-inp-' + type);
  const text = inp.value.trim();
  if (!text) return;
  inp.value = '';
  
  const container = document.getElementById('chat-msg-' + type);
  if (!container) return;
  
  const userBubble = document.createElement('div');
  userBubble.className = 'chat-bubble user';
  userBubble.textContent = text;
  container.appendChild(userBubble);
  
  const typingEl = document.getElementById('typing-' + type);
  if (typingEl) typingEl.style.display = 'block';
  
  container.scrollTop = container.scrollHeight;
  
  setTimeout(() => {
    if (typingEl) typingEl.style.display = 'none';
    const responses = aiResponses[type];
    const prefix = responses[Math.floor(Math.random() * responses.length)];
    const aiBubble = document.createElement('div');
    aiBubble.className = 'chat-bubble ai';
    
    // Simple response logic
    let response = prefix;
    if (text.toLowerCase().includes('vitamin') || text.toLowerCase().includes('bitamina')) {
      response += 'Ang mga importanteng vitamins para sa iyong stage: Folic Acid (400-800mcg), Iron (27mg), Calcium (1000mg), Vitamin D (600IU), at DHA. Kumuha ng prenatal vitamins na may lahat ng ito. Konsultahin ang iyong OB para sa eksaktong dosage. 💊';
    } else if (text.toLowerCase().includes('sakit') || text.toLowerCase().includes('pain') || text.toLowerCase().includes('cramp')) {
      response += 'Ang mild cramping ay maaaring normal, pero kung malakas at sinasamahan ng pagdurugo o fever, pumunta agad sa ER o tumawag ng emergency. Ang iyong PregnaCare app ay maaaring mag-alert sa mga malapit na health facility. 🏥';
    } else if (text.toLowerCase().includes('late') || text.toLowerCase().includes('delayed') || text.toLowerCase().includes('missed')) {
      response += 'Ang delayed period ay maaaring sanhi ng stress, pagbabago ng timbang, o pagbubuntis. Mag-home pregnancy test muna. Kung positive, i-switch sa Pregnancy Mode ng PregnaCare para magsimulang mag-track. 🌸';
    } else {
      response += 'Ito ay isang mahalagang concern. Inirerekomenda ko na i-log mo ang lahat ng symptoms sa app at kumonsulta sa iyong OB-GYN o sa malapit na health center para sa mas detalyadong payo. Nandito ang PregnaCare para suportahan ka 24/7! 💜';
    }
    
    aiBubble.textContent = response;
    container.appendChild(aiBubble);
    container.scrollTop = container.scrollHeight;
  }, 1500);
}
 
function quickAsk(q, type) {
  document.getElementById('chat-inp-' + type).value = q;
  sendChat(type);
}
 
// ── VOICE ──
function toggleVoice(btn) {
  btn.classList.toggle('listening');
  if (btn.classList.contains('listening')) {
    showToast('Nakikinig... Magsalita sa Tagalog 🎤');
    setTimeout(() => { btn.classList.remove('listening'); showToast('Na-transcribe ang boses mo! 📝'); }, 3000);
  }
}
 
// ── WELLNESS TABS ──
function switchWellTab(el, tab) {
  el.parentElement.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  ['ar','mood','bf','hub'].forEach(t => {
    const el2 = document.getElementById('well-' + t);
    if (el2) el2.style.display = t === tab ? '' : 'none';
  });
}
function switchChatTab(el, tab) {
  el.parentElement.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  ['preg','period','tele'].forEach(t => {
    const el2 = document.getElementById('chat-' + t);
    if (el2) el2.style.display = t === tab ? '' : 'none';
  });
}
 
// ── MOOD ──
function selectMood(el, mood) {
  document.querySelectorAll('#mood-select .mood-pill').forEach(p => p.classList.remove('selected'));
  el.classList.add('selected');
  const tips = { happy:'Napakaganda nyan! Ituloy ang positibong mood. 🌸', calm:'Perfect para sa baby! Stress-free ang pinakamainam. 😌', anxious:'Normal ang anxiety — subukang mag-deep breathing. 💜', sad:'Okay lang maging malungkot. Kumausap sa kapamilya o sa aming wellness coach. 🤗', angry:'Normal ang mood swings sa pagbubuntis. Mag-rest at kumain ng masustansya. 😤→😌', tired:'Mag-rest! Ang katawan mo ay nagtatrabaho nang husto para sa baby. 💤' };
  showToast(tips[mood] || 'Na-save ang mood mo! 💜');
}
 
// ── BREASTFEEDING TIMER ──
function toggleTimer(side) {
  const t = timers[side];
  const btn = document.getElementById('btn-' + side);
  if (t.running) {
    clearInterval(t.interval); t.running = false;
    btn.textContent = 'Simula'; btn.classList.remove('running');
  } else {
    t.running = true; btn.textContent = 'Ihinto'; btn.classList.add('running');
    t.interval = setInterval(() => {
      t.seconds++;
      document.getElementById('timer-' + side).textContent = formatTime(t.seconds);
    }, 1000);
  }
}
function formatTime(s) {
  const m = Math.floor(s / 60), sec = s % 60;
  return String(m).padStart(2,'0') + ':' + String(sec).padStart(2,'0');
}
 
// ── MISC ──
function togglePill(el) { el.classList.toggle('selected'); }
function likePost(el) {
  const txt = el.textContent;
  const num = parseInt(txt.match(/\d+/)[0]);
  el.innerHTML = el.innerHTML.replace(/\d+ Likes/, (num + 1) + ' Likes');
  el.style.color = 'var(--rose)';
}
function triggerEmergency() {
  showToast('🚨 SOS Sent! Isinasabalikat ang lokasyon at vital signs...');
  setTimeout(() => showToast('📍 3 nearby facilities notified! Midwife en route.'), 2000);
}
 
// ── TOAST ──
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3000);
}

</script>
